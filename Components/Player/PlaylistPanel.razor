@implements IDisposable
@inject PlaylistService Playlist
@inject PlaybackService Playback
@inject FavoritesService Favorites
@inject IFileSystemActionsService FileSystemActions
@inject ToastService Toasts
@using MauiMediaPlayer.Models

@* Playlist sidebar: source chips, multi-select media-kind toggles (playback +
   list), sort dropdown, and hover-revealed row actions. Collapse state is owned
   by PlayerShell so the toggle button there stays in sync. *@

<aside class="playlist-panel @(IsCollapsed ? "is-collapsed" : null)"
       @onkeydown:stopPropagation="true">
    <div class="playlist-header">
        <h2 class="playlist-title">Playlist</h2>
        <span class="playlist-stats">@StatsLine</span>
        <div class="ms-auto d-flex align-items-center gap-1">
            <button class="icon-btn"
                    type="button"
                    title="Hide playlist (L)"
                    aria-label="Hide playlist"
                    @onclick="RequestCollapseAsync">
                <Icon Name="chevron-right" />
            </button>
        </div>
    </div>

    <div class="playlist-toolbar">
        <div class="input-icon">
            <Icon Name="search" Size="14" />
            <input type="text"
                   placeholder="Search playlist"
                   value="@_filter"
                   @oninput="OnFilterChanged"
                   aria-label="Search playlist" />
            @if (!string.IsNullOrEmpty(_filter))
            {
                <button class="icon-btn" type="button" title="Clear search"
                        style="height:24px;width:24px;"
                        @onclick="() => SetFilter(string.Empty)">
                    <Icon Name="x-lg" Size="10" />
                </button>
            }
        </div>

        <div class="playlist-filter-chips" role="tablist" aria-label="Playlist source">
            @foreach (var chip in SourceChips)
            {
                <button class="filter-chip @(Playback.Settings.PlaylistSource == chip.Source ? "is-active" : null)"
                        type="button"
                        role="tab"
                        aria-selected="@(Playback.Settings.PlaylistSource == chip.Source ? "true" : "false")"
                        @onclick="() => SetPlaylistSourceAsync(chip.Source)">
                    @chip.Label
                </button>
            }
        </div>

        <div class="playlist-filter-chips" role="group" aria-label="Media types to play">
            <button class="filter-chip @(IsAllKindsEnabled ? "is-active" : null)"
                    type="button"
                    aria-pressed="@(IsAllKindsEnabled ? "true" : "false")"
                    title="Enable images, videos, and GIFs"
                    @onclick="EnableAllMediaKindsAsync">
                All
            </button>
            @foreach (var chip in KindChips)
            {
                <button class="filter-chip @(IsKindEnabled(chip.Kind) ? "is-active" : null)"
                        type="button"
                        aria-pressed="@(IsKindEnabled(chip.Kind) ? "true" : "false")"
                        @onclick="() => ToggleMediaKindAsync(chip.Kind)">
                    @chip.Label
                </button>
            }
        </div>

        <div class="playlist-toolbar-actions">
            <div class="d-flex align-items-center gap-1">
                <select class="form-select form-select-sm"
                        value="@_sortMode"
                        style="max-width:9rem;"
                        @onchange="SetSortAsync"
                        aria-label="Sort order">
                    <option value="@SortMode.Name">Sort: Name</option>
                    <option value="@SortMode.Path">Sort: Path</option>
                    <option value="@SortMode.Newest">Sort: Newest</option>
                </select>
                <button class="icon-btn"
                        type="button"
                        title="Randomize playlist order"
                        aria-label="Randomize playlist order"
                        @onclick="RandomizeOrderAsync"
                        disabled="@(!Playlist.HasItems)">
                    <Icon Name="dice-5-fill" />
                </button>
            </div>
        </div>
    </div>

    @if (Playlist.Items.Count == 0)
    {
        <div class="playlist-empty">
            <Icon Name="list" Size="22" />
            <div>Add files or a folder to build a playlist.</div>
        </div>
    }
    else if (FilteredItems.Count == 0)
    {
        <div class="playlist-empty">
            @if (Playback.Settings.PlaylistSource == PlaylistSource.FavoritesOnly
                 && Playback.FavoriteCountInPlaylist == 0)
            {
                <Icon Name="heart-fill" Size="22" />
                <div>No favorites in this library.</div>
                <div class="form-text">Use the heart on a pane while hovering to add favorites.</div>
            }
            else
            {
                <Icon Name="search" Size="22" />
                <div>No items match the current filters.</div>
                <button class="btn btn-sm btn-outline-secondary" type="button"
                        @onclick="ClearFiltersAsync">Reset filters</button>
            }
        </div>
    }
    else
    {
        <ul class="playlist-items">
            <Virtualize Items="FilteredItems" Context="item" ItemSize="52">
                @{
                    var isCurrent = Playlist.CurrentItem?.Id == item.Id;
                }
                <li class="playlist-item @(isCurrent ? "is-current" : null)">
                    <button class="playlist-item-main"
                            type="button"
                            title="@item.FilePath"
                            @onclick="() => Playback.SelectAsync(item)">
                        @if (Favorites.IsFavorite(item.FilePath))
                        {
                            <span class="playlist-item-favorite" title="Favorite" aria-hidden="true">
                                <Icon Name="heart-fill" Size="12" />
                            </span>
                        }
                        <span class="playlist-item-icon">
                            <Icon Name="@IconForKind(item.Kind)" Size="14" />
                        </span>
                        <span class="playlist-item-body">
                            <span class="playlist-item-title">@item.DisplayName</span>
                            <span class="playlist-item-meta">@item.FilePath</span>
                        </span>
                    </button>
                    <span class="playlist-item-actions">
                        <button class="icon-btn"
                                type="button"
                                style="height:26px;width:26px;"
                                title="Reveal in file manager"
                                aria-label="Reveal in file manager"
                                @onclick="() => RevealAsync(item)">
                            <Icon Name="box-arrow-up-right" Size="12" />
                        </button>
                        <button class="icon-btn"
                                type="button"
                                style="height:26px;width:26px;"
                                title="Remove from playlist"
                                aria-label="Remove from playlist"
                                @onclick="() => RemoveAsync(item)">
                            <Icon Name="trash" Size="12" />
                        </button>
                    </span>
                </li>
            </Virtualize>
        </ul>
    }
</aside>

@code {
    [Parameter] public bool IsCollapsed { get; set; }
    [Parameter] public EventCallback<bool> IsCollapsedChanged { get; set; }
    [Parameter] public EventCallback<string> OnStatusChanged { get; set; }

    private enum SortMode { Name, Path, Newest }

    private string _filter = string.Empty;
    private SortMode _sortMode = SortMode.Name;
    private List<MediaItem> _filteredItems = [];

    private static readonly IReadOnlyList<(PlaylistSource Source, string Label)> SourceChips =
    [
        (PlaylistSource.AllLibrary, "All"),
        (PlaylistSource.FavoritesOnly, "Favorites"),
    ];

    private static readonly IReadOnlyList<(MediaKind Kind, string Label)> KindChips =
    [
        (MediaKind.Image, "Images"),
        (MediaKind.Video, "Videos"),
        (MediaKind.Gif, "GIFs"),
    ];

    private bool IsAllKindsEnabled => Playback.Settings.IsAllMediaKindsEnabled;

    private bool IsKindEnabled(MediaKind kind) => Playback.Settings.IsMediaKindEnabled(kind);

    private string StatsLine
    {
        get
        {
            var total = Playlist.Items.Count;

            if (total == 0)
            {
                return "0 items";
            }

            var imageCount = 0;
            var videoCount = 0;
            var gifCount = 0;

            foreach (var item in Playlist.Items)
            {
                switch (item.Kind)
                {
                    case MediaKind.Image: imageCount++; break;
                    case MediaKind.Video: videoCount++; break;
                    case MediaKind.Gif: gifCount++; break;
                }
            }

            var favoriteCount = Playback.FavoriteCountInPlaylist;
            var parts = new List<string>();

            if (favoriteCount > 0)
            {
                parts.Add($"{favoriteCount} favorite{(favoriteCount == 1 ? "" : "s")}");
            }

            parts.Add($"{total} total");

            if (Playback.Settings.PlaylistSource == PlaylistSource.FavoritesOnly
                || !Playback.Settings.IsAllMediaKindsEnabled)
            {
                var shown = _filteredItems.Count;
                parts.Add($"{shown} shown");
            }
            else
            {
                if (videoCount > 0) parts.Add($"{videoCount} video{(videoCount == 1 ? "" : "s")}");
                if (imageCount > 0) parts.Add($"{imageCount} image{(imageCount == 1 ? "" : "s")}");
                if (gifCount > 0) parts.Add($"{gifCount} GIF{(gifCount == 1 ? "" : "s")}");
            }

            return string.Join(" \u00B7 ", parts);
        }
    }

    private ICollection<MediaItem> FilteredItems => _filteredItems;

    protected override void OnInitialized()
    {
        Playlist.Changed += OnStateChanged;
        Playback.Changed += OnStateChanged;
        Favorites.Changed += OnStateChanged;
        RebuildFilteredItems();
    }

    private void OnFilterChanged(ChangeEventArgs args)
    {
        SetFilter(args.Value?.ToString() ?? string.Empty);
    }

    private void SetFilter(string value)
    {
        _filter = value;
        RebuildFilteredItems();
    }

    private async Task EnableAllMediaKindsAsync()
    {
        if (Playback.Settings.IsAllMediaKindsEnabled)
        {
            return;
        }

        await Playback.UpdateSettingsAsync(s => s.EnabledMediaKinds = PlaybackMediaKinds.All);
        RebuildFilteredItems();
    }

    private async Task ToggleMediaKindAsync(MediaKind kind)
    {
        var flag = KindToFlag(kind);
        var current = Playback.Settings.EnabledMediaKinds;

        if (current.HasFlag(flag))
        {
            var remaining = current & ~flag;
            if (remaining == PlaybackMediaKinds.None)
            {
                Toasts.Info("At least one media type must stay enabled.");
                return;
            }

            await Playback.UpdateSettingsAsync(s => s.EnabledMediaKinds = remaining);
        }
        else
        {
            await Playback.UpdateSettingsAsync(s => s.EnabledMediaKinds = current | flag);
        }

        RebuildFilteredItems();
    }

    private static PlaybackMediaKinds KindToFlag(MediaKind kind) => kind switch
    {
        MediaKind.Image => PlaybackMediaKinds.Images,
        MediaKind.Video => PlaybackMediaKinds.Videos,
        MediaKind.Gif => PlaybackMediaKinds.Gifs,
        _ => PlaybackMediaKinds.None
    };

    private async Task SetPlaylistSourceAsync(PlaylistSource source)
    {
        if (Playback.Settings.PlaylistSource == source)
        {
            return;
        }

        await Playback.UpdateSettingsAsync(s => s.PlaylistSource = source);
        RebuildFilteredItems();
    }

    private void RebuildFilteredItems()
    {
        IEnumerable<MediaItem> items = Playlist.Items;

        if (Playback.Settings.PlaylistSource == PlaylistSource.FavoritesOnly)
        {
            items = items.Where(item => Favorites.IsFavorite(item.FilePath));
        }

        items = items.Where(item => Playback.Settings.IsMediaKindEnabled(item.Kind));

        if (!string.IsNullOrWhiteSpace(_filter))
        {
            items = items.Where(item =>
                item.DisplayName.Contains(_filter, StringComparison.OrdinalIgnoreCase)
                || item.FilePath.Contains(_filter, StringComparison.OrdinalIgnoreCase));
        }

        _filteredItems = items.ToList();
    }

    private async Task SetSortAsync(ChangeEventArgs args)
    {
        if (!Enum.TryParse<SortMode>(args.Value?.ToString(), out var mode))
        {
            return;
        }

        _sortMode = mode;

        switch (mode)
        {
            case SortMode.Name:
                Playlist.SortByName();
                break;
            case SortMode.Path:
                Playlist.SortByPath();
                break;
            case SortMode.Newest:
                Playlist.SortByDateModified();
                break;
        }

        await Playback.RefreshPlaylistAsync();
    }

    private async Task RandomizeOrderAsync()
    {
        Playlist.ShuffleItems();
        await Playback.RefreshPlaylistAsync();
    }

    private async Task ClearFiltersAsync()
    {
        _filter = string.Empty;

        await Playback.UpdateSettingsAsync(s =>
        {
            s.PlaylistSource = PlaylistSource.AllLibrary;
            s.EnabledMediaKinds = PlaybackMediaKinds.All;
        });

        RebuildFilteredItems();
    }

    private async Task RevealAsync(MediaItem item)
    {
        try
        {
            await FileSystemActions.RevealInFileManagerAsync(item);
        }
        catch (Exception exception)
        {
            Toasts.Error($"Could not reveal {item.DisplayName}: {exception.Message}");
        }
    }

    private async Task RemoveAsync(MediaItem item)
    {
        var wasCurrent = Playlist.CurrentItem?.Id == item.Id;
        var previousStatus = Playback.Status;
        Playlist.Remove(item);

        if (!Playlist.HasItems)
        {
            await Playback.StopAsync();
        }
        else if (wasCurrent)
        {
            if (previousStatus == PlaybackStatus.Playing)
            {
                await Playback.PlayAsync();
            }
            else
            {
                await Playback.StopAsync();
            }
        }

        Toasts.Info($"Removed {item.DisplayName}");
        await OnStatusChanged.InvokeAsync($"Removed {item.DisplayName}.");
    }

    private async Task RequestCollapseAsync()
    {
        IsCollapsed = true;
        await IsCollapsedChanged.InvokeAsync(IsCollapsed);
    }

    private static string IconForKind(MediaKind kind) => kind switch
    {
        MediaKind.Image => "image",
        MediaKind.Video => "film",
        MediaKind.Gif => "file-earmark-music",
        _ => "file-earmark",
    };

    private void OnStateChanged()
    {
        RebuildFilteredItems();
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Playlist.Changed -= OnStateChanged;
        Playback.Changed -= OnStateChanged;
        Favorites.Changed -= OnStateChanged;
    }
}
