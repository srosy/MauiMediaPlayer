@implements IDisposable
@inject PopoverStateService Popovers
@inject NativeVideoPlaybackService NativeVideo

@* Gear trigger only; the panel is rendered at the shell root via SettingsPopoverPanel. *@

<button class="icon-btn @(IsOpen ? "is-active" : null)"
        type="button"
        title="Playback settings"
        aria-label="Playback settings"
        aria-haspopup="true"
        aria-expanded="@(IsOpen ? "true" : "false")"
        @onclick="Toggle">
    <Icon Name="gear-fill" />
</button>

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback<bool> IsOpenChanged { get; set; }

    protected override void OnInitialized()
    {
        Popovers.CloseRequested += OnCloseRequested;
    }

    private async Task Toggle()
    {
        if (!IsOpen)
        {
            Popovers.CloseAll();
        }

        IsOpen = !IsOpen;
        Popovers.SetSettingsPanelOpen(IsOpen);
        Popovers.SetOpen(this, IsOpen, suppressNativeVideo: true);
        await SyncNativeOverlaySuppressionAsync();
        await IsOpenChanged.InvokeAsync(IsOpen);
    }

    private void OnCloseRequested()
    {
        if (!IsOpen)
        {
            return;
        }

        IsOpen = false;
        Popovers.SetOpen(this, false);
        Popovers.SetSettingsPanelOpen(false);
        _ = InvokeAsync(async () =>
        {
            await SyncNativeOverlaySuppressionAsync();
            await IsOpenChanged.InvokeAsync(IsOpen);
            StateHasChanged();
        });
    }

    private Task SyncNativeOverlaySuppressionAsync() =>
        NativeVideo.SuppressForOverlayAsync(Popovers.AnySuppressesNativeVideo);

    public void Dispose()
    {
        Popovers.CloseRequested -= OnCloseRequested;
        Popovers.SetOpen(this, false);
        Popovers.SetSettingsPanelOpen(false);
    }
}
